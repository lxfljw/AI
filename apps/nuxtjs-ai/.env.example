# 复制为 .env 后填写，.env 不会提交 Git
# cp .env.example .env

NUXT_OLLAMA_HOST=http://host.docker.internal:11434
NUXT_OLLAMA_MODEL=qwen3.5:0.8b

# 宿主机 pnpm dev 用 127.0.0.1；Docker compose 用 host.docker.internal
NUXT_RAG_DATABASE_URL=postgresql://rag:rag@host.docker.internal:5432/rag
NUXT_RAG_EMBED_MODEL=mxbai-embed-large:latest
NUXT_RAG_SEARCH_TOP_K=5
# 可选，默认 apps/server/data/students100.txt
# NUXT_RAG_STUDENTS_FILE=

NUXT_FEISHU_APP_ID=
NUXT_FEISHU_APP_SECRET=

# Webhook 模式才需要
NUXT_FEISHU_VERIFICATION_TOKEN=
NUXT_FEISHU_ENCRYPT_KEY=
